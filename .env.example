# Thumper configuration
# Copy to .env and adjust for your environment.

# Database URL (SQLAlchemy format). A bare path is treated as SQLite.
# Examples:
#   thumper.db                          (SQLite, relative to repo root)
#   postgresql+psycopg://user:pass@localhost/thumper
#   mysql+pymysql://user:pass@localhost/thumper
THUMPER_DB=thumper.db

# Public base URL that endpoints use to reach this server.
# Must be reachable from managed machines in production.
THUMPER_BASE_URL=http://localhost:8000

# Enrollment token - agents present this to POST /api/enroll.
# Generate a strong random value for production.
THUMPER_ENROLL_TOKEN=dev-enroll-token

# Install token - gates access to GET /api/install.sh.
# The installer embeds the enroll token, so this must stay secret.
# Generate a strong random value for production.
THUMPER_INSTALL_TOKEN=dev-install-token

# Path to the built UI (ui/dist). Used in Docker / monolith mode.
# THUMPER_UI_DIST=ui/dist

# Path to the endpoint agent script.
# THUMPER_AGENT_PATH=agent/thumper_agent.sh

# Directory containing plugin subdirectories.
# THUMPER_PLUGINS_DIR=plugins

# Dashboard auto-refresh interval in seconds. 0 disables.
THUMPER_DASHBOARD_REFRESH=60
